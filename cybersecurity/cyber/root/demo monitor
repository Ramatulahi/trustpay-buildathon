import time
import sys

def log_visual(status, message):
    color = "\033[92m" if status == "PASS" else "\033[91m"
    reset = "\033[0m"
    print(f"[{time.strftime('%H:%M:%S')}] {color}{status}{reset} | {message}")
    return status # We return the status so we can check it later

